{
  "name": "omnimesh",
  "version": "0.1.0",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.6.3"
  },
  "description": "Sovereign AI fabric — turn your LAN into a private AI cluster. One command to share compute across all your devices.",
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=22.17.0"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:host": "bun run --cwd packages/host dev",
    "dev:web": "bun run --cwd packages/web dev",
    "dev:cli": "bun run --cwd packages/cli dev",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -b",
    "docs:gen": "bun run docs/scripts/gen-capabilities.ts",
    "docs:build": "bun run docs:gen && bun run docs/scripts/build.ts",
    "docs:serve": "python3 -m http.server 3006 --directory docs/dist",
    "clean": "rm -rf packages/*/dist packages/*/node_modules/.cache docs/dist"
  },
  "type": "module",
  "workspaces": [
    "packages/cli",
    "packages/host",
    "packages/installer",
    "packages/web"
  ],
  "dependencies": {
    "bonjour-service": "^1.4.1"
  }
}
