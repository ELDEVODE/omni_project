{
  "name": "@omnimesh/installer",
  "version": "0.1.0",
  "description": "OmniMesh installer — modular capability registry (qvac, ffmpeg, vulkan, openwakeword, bonjour). Used by the omni CLI and by node-side install dispatchers.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./registry": "./src/registry.ts",
    "./runner": "./src/runner.ts",
    "./capabilities": "./src/capabilities/index.ts"
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omnimesh/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "license": "MIT"
}
