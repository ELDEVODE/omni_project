{
  "name": "@omnimesh/host",
  "version": "0.1.0",
  "description": "OmniMesh host — mesh coordinator, QVAC orchestrator, dashboard server.",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "omni-host": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist --external @qvac/sdk",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omnimesh/installer": "workspace:*",
    "bonjour-service": "^1.3.0"
  },
  "peerDependencies": {
    "@qvac/sdk": ""
  },
  "peerDependenciesMeta": {
    "@qvac/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
