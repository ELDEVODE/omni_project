{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": { "enabled": false },
	"organizeImports": { "enabled": true },
	"files": {
		"ignoreUnknown": true,
		"include": [
			"packages/**/src/**/*.ts",
			"packages/**/src/**/*.tsx",
			"packages/**/App.tsx",
			"packages/**/index.ts",
			"packages/**/test/**/*.ts",
			"docs/install.sh"
		],
		"ignore": ["**/ambient.d.ts"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConsole": "off",
				"noExplicitAny": "warn"
			},
			"style": {
				"useImportType": "warn",
				"useNodejsImportProtocol": "warn",
				"useConsistentArrayType": {
					"level": "warn",
					"options": { "syntax": "shorthand" }
				},
				"noNonNullAssertion": "warn"
			},
			"complexity": {
				"useLiteralKeys": "warn"
			},
			"a11y": {
				"useButtonType": "warn",
				"noSvgWithoutTitle": "warn"
			},
			"correctness": {
				"useExhaustiveDependencies": "warn"
			},
			"performance": {
				"noDelete": "warn"
			}
		}
	},
	"overrides": [
		{
			"include": ["**/*.test.ts", "**/test/**/*.ts"],
			"linter": {
				"rules": {
					"performance": {
						"noDelete": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"trailingCommas": "all",
			"arrowParentheses": "always"
		}
	},
	"json": {
		"formatter": {
			"indentWidth": 2,
			"trailingCommas": "none"
		}
	}
}
